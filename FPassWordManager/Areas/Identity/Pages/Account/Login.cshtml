@page
@model LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="auth-card">

    <div class="auth-icon">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <rect x="3" y="10" width="16" height="11" rx="2.5" fill="currentColor" opacity="0.85" />
            <path d="M7 10V7.5a4 4 0 0 1 8 0V10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none" />
            <circle cx="11" cy="15.5" r="1.5" fill="white" opacity="0.8" />
        </svg>
    </div>

    <h1 class="auth-title">Welcome back</h1>
    <p class="auth-subtitle">Sign in to your app.</p>

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <form id="loginForm" method="post">

        <div class="form-group">
            <label class="form-label">Email address</label>
            <div class="input-wrapper">
                <span class="input-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                        <rect x="1.5" y="3.5" width="13" height="9" rx="1.5" stroke="currentColor" stroke-width="1.3" fill="none" />
                        <path d="M1.5 5.5l6.5 4 6.5-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                    </svg>
                </span>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="you@example.com" />
            </div>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                <label class="form-label" style="margin:0">Password</label>
                <a asp-page="./ForgotPassword" class="forgot-link">Forgot password?</a>
            </div>
            <div class="input-wrapper">
                <span class="input-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                        <circle cx="6.5" cy="6.5" r="3.5" stroke="currentColor" stroke-width="1.3" fill="none" />
                        <path d="M9.5 9.5L14 14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                    </svg>
                </span>
                <input asp-for="Input.Password" class="form-control" type="password" autocomplete="current-password" placeholder="••••••••" />
            </div>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <div class="form-group" style="margin-top:0.5rem;">
            <label class="form-check">
                <input class="form-check-input" asp-for="Input.RememberMe" type="checkbox" />
                <span class="form-check-label">Keep me signed in</span>
            </label>
        </div>

        <div style="margin-top:1.5rem;">
            <button type="submit" class="btn-vault">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                    <path d="M10 2h3a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1h-3M7 11l3-3-3-3M10 8H2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Sign in
            </button>
        </div>

    </form>

    <div class="auth-footer">
        Don't have an account? <a asp-area="Identity" asp-page="/Account/Register">Create one</a>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
