@page
@model FPasswordManager.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    ViewData["Title"] = "Profile";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="profile-page">

    <div class="profile-header">
        <div class="profile-avatar-lg" id="profile-initials">—</div>
        <div>
            <h1 class="dash-title" id="profile-display-name">Loading…</h1>
            <p class="dash-subtitle" id="profile-email-display" style="font-size:13px"></p>
        </div>
    </div>

    <div class="profile-grid">

        <div class="profile-card">
            <div class="profile-card-header">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="5.5" r="3" stroke="currentColor" stroke-width="1.3" fill="none" />
                    <path d="M2 14c0-3.314 2.686-5 6-5s6 1.686 6 5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" fill="none" />
                </svg>
                Account details
            </div>
            <form id="profile-form" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors" style="display:none"></div>
                <div class="form-group">
                    <label class="form-label">Username</label>
                    <input asp-for="Input.Username" class="form-control" placeholder="your username" />
                    <span asp-validation-for="Input.Username" class="text-danger"></span>
                </div>
                <div class="form-row-2">
                    <div class="form-group">
                        <label class="form-label">First name</label>
                        <input asp-for="Input.FirstName" class="form-control" placeholder="First name" />
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Last name</label>
                        <input asp-for="Input.LastName" class="form-control" placeholder="Last name" />
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control" disabled style="opacity:0.5;cursor:not-allowed" />
                    <p style="font-size:12px;color:var(--text-muted);margin-top:5px">Email cannot be changed.</p>
                </div>
                <p id="profile-status" class="field-error" style="color:var(--accent)"></p>
                <div style="display:flex;gap:8px;margin-top:0.25rem">
                    <button type="submit" class="btn-vault btn-sm">Save changes</button>
                </div>
            </form>
        </div>

        <div class="profile-card">
            <div class="profile-card-header">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                    <rect x="3" y="8" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="1.3" fill="none" />
                    <path d="M5 8V6a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" fill="none" />
                </svg>
                Change password
            </div>
            <form id="change-password-form" method="post" asp-page-handler="ChangePassword">
                <div class="form-group">
                    <label class="form-label">Current password</label>
                    <div class="input-wrapper">
                        <input asp-for="PasswordInput.OldPassword" type="password" class="form-control" placeholder="••••••••" style="padding-right:40px" />
                        <button type="button" class="reveal-btn" onclick="toggleRevealInput('Input_PasswordInput_OldPassword', this)">
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><ellipse cx="8" cy="8" rx="6.5" ry="4" stroke="currentColor" stroke-width="1.3" fill="none" /><circle cx="8" cy="8" r="2" fill="currentColor" /></svg>
                        </button>
                    </div>
                    <span asp-validation-for="PasswordInput.OldPassword" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">New password</label>
                    <div class="input-wrapper">
                        <input asp-for="PasswordInput.NewPassword" type="password" class="form-control" placeholder="••••••••" style="padding-right:40px" />
                        <button type="button" class="reveal-btn" onclick="toggleRevealInput('Input_PasswordInput_NewPassword', this)">
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><ellipse cx="8" cy="8" rx="6.5" ry="4" stroke="currentColor" stroke-width="1.3" fill="none" /><circle cx="8" cy="8" r="2" fill="currentColor" /></svg>
                        </button>
                    </div>
                    <span asp-validation-for="PasswordInput.NewPassword" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Confirm new password</label>
                    <input asp-for="PasswordInput.ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="PasswordInput.ConfirmPassword" class="text-danger"></span>
                </div>
                <p id="password-status" class="field-error" style="color:var(--accent)"></p>
                <button type="submit" class="btn-vault btn-sm">Update password</button>
            </form>
        </div>

        <div class="profile-card">
            <div class="profile-card-header">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.3" fill="none" />
                    <path d="M8 5v3l2 1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                </svg>
                Change vault PIN
            </div>
            <form id="change-pin-form" method="post" asp-page-handler="ChangePin">
                <div class="form-group">
                    <label class="form-label">New PIN <span style="color:var(--text-muted);font-size:12px">(5 digits)</span></label>
                    <input asp-for="PinInput.NewPin" class="form-control pin-input" type="password" maxlength="5" inputmode="numeric" placeholder="•••••" />
                    <span asp-validation-for="PinInput.NewPin" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Confirm PIN</label>
                    <input asp-for="PinInput.ConfirmPin" class="form-control pin-input" type="password" maxlength="5" inputmode="numeric" placeholder="•••••" />
                    <span asp-validation-for="PinInput.ConfirmPin" class="text-danger"></span>
                </div>
                <p id="pin-status" class="field-error" style="color:var(--accent)"></p>
                <button type="submit" class="btn-vault btn-sm">Update PIN</button>
            </form>
        </div>

        <!-- Delete account card -->
        <div class="profile-card profile-card-danger">
            <div class="profile-card-header" style="color:var(--danger)">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                    <path d="M8 2L2 14h12L8 2z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" fill="none" />
                    <path d="M8 7v3M8 11.5v.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                </svg>
                Delete Account
            </div>
            <p style="font-size:13.5px;color:var(--text-secondary);margin-bottom:1rem;line-height:1.65">
                Deleting your account will permanently remove all your folders, credentials, cards, and security keys. This action cannot be undone.
            </p>
            <button type="button" class="btn-danger btn-sm" onclick="openDeleteAccountModal()">
                Delete my account
            </button>
        </div>

    </div>
</div>

<!-- Delete Account Confirmation-->
<div class="modal-backdrop" id="modal-delete-account" onclick="closeDeleteAccountModal()">
    <div class="modal-box modal-sm" onclick="event.stopPropagation()" style="max-width:420px">
        <div class="modal-header" style="border-bottom-color:rgba(248,113,113,0.2)">
            <div style="display:flex;align-items:center;gap:9px">
                <div style="width:32px;height:32px;background:var(--danger-dim);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;color:var(--danger);flex-shrink:0">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                        <path d="M8 2L2 14h12L8 2z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" fill="none" />
                        <path d="M8 7v3M8 11.5v.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                    </svg>
                </div>
                <span style="color:var(--danger)">Delete account</span>
            </div>
            <button class="modal-close" onclick="closeDeleteAccountModal()">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" /></svg>
            </button>
        </div>
        <div class="modal-body">
            <p style="font-size:14px;color:var(--text-secondary);line-height:1.7;margin-bottom:1.25rem">
                This will <strong style="color:var(--text-primary)">permanently delete</strong> your account and everything inside it — all folders, web logins, cards, and security keys. There is no way to recover this data.
            </p>
            <div style="background:var(--danger-dim);border:1px solid rgba(248,113,113,0.2);border-radius:var(--radius-sm);padding:10px 14px;margin-bottom:1.25rem">
                <p style="font-size:13px;color:var(--danger);margin:0">
                    Type <strong>DELETE</strong> below to confirm.
                </p>
            </div>
            <input class="form-control" id="delete-confirm-input"
                   placeholder="Type DELETE to confirm"
                   oninput="onDeleteConfirmInput(this)"
                   autocomplete="off" />
            <p id="delete-account-error" class="field-error" style="margin-top:6px"></p>
        </div>
        <div class="modal-footer" style="border-top-color:rgba(248,113,113,0.15)">
            <button class="btn-ghost" onclick="closeDeleteAccountModal()">Cancel</button>
            <form method="post" asp-page-handler="DeleteAccount" id="delete-account-form">
                <button type="submit" id="delete-account-btn" class="btn-danger btn-sm" disabled
                        style="opacity:0.4;cursor:not-allowed;transition:var(--transition)">
                    Delete forever
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var fn    = document.querySelector('[name="Input.FirstName"]').value.trim();
            var ln    = document.querySelector('[name="Input.LastName"]').value.trim();
            var email = document.querySelector('[name="Input.Email"]').value.trim();
            var user  = document.querySelector('[name="Input.Username"]').value.trim();

            var displayName = (fn || ln) ? ((fn + ' ' + ln).trim()) : (user || email);
            var initials    = displayName.split(' ').map(function(p) { return p[0]; }).join('').toUpperCase().slice(0, 2) || '?';

            document.getElementById('profile-initials').textContent     = initials;
            document.getElementById('profile-display-name').textContent = displayName;
            document.getElementById('profile-email-display').textContent = email;

            var profileMsg  = '@TempData["ProfileSuccess"]';
            var passwordMsg = '@TempData["PasswordSuccess"]';
            var pinMsg      = '@TempData["PinSuccess"]';
            var errMsg      = '@TempData["Error"]';

            if (profileMsg)  showStatus('profile-status',  profileMsg,  false);
            if (passwordMsg) showStatus('password-status', passwordMsg, false);
            if (pinMsg)      showStatus('pin-status',       pinMsg,      false);
            if (errMsg)      showStatus('profile-status',   errMsg,      true);
        });

        function showStatus(elId, msg, isError) {
            var el = document.getElementById(elId);
            if (!el || !msg || msg === '') return;
            el.textContent = msg;
            el.style.color = isError ? 'var(--danger)' : 'var(--accent)';
        }

        function toggleRevealInput(id, btn) {
            var inp = document.getElementById(id);
            if (!inp) return;
            inp.type = inp.type === 'text' ? 'password' : 'text';
            btn.style.opacity = inp.type === 'text' ? '1' : '0.5';
        }

        // Delete account 
        function openDeleteAccountModal() {
            document.getElementById('delete-confirm-input').value = '';
            document.getElementById('delete-account-error').textContent = '';
            var btn = document.getElementById('delete-account-btn');
            btn.disabled = true;
            btn.style.opacity = '0.4';
            btn.style.cursor = 'not-allowed';
            document.getElementById('modal-delete-account').classList.add('active');
            document.body.style.overflow = 'hidden';
            setTimeout(function() { document.getElementById('delete-confirm-input').focus(); }, 50);
        }

        function closeDeleteAccountModal() {
            document.getElementById('modal-delete-account').classList.remove('active');
            document.body.style.overflow = '';
        }

        function onDeleteConfirmInput(input) {
            var btn = document.getElementById('delete-account-btn');
            var isMatch = input.value === 'DELETE';
            btn.disabled = !isMatch;
            btn.style.opacity = isMatch ? '1' : '0.4';
            btn.style.cursor  = isMatch ? 'pointer' : 'not-allowed';
            document.getElementById('delete-account-error').textContent = '';
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeDeleteAccountModal();
        });
    </script>
}
