@page
@model RegisterModel
@{
    ViewData["Title"] = "Create account";
}

<div class="auth-card" style="max-width:520px;">

    <div class="auth-icon">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <circle cx="9" cy="7" r="3.5" stroke="currentColor" stroke-width="1.7" fill="none" />
            <path d="M2 18c0-3.866 3.134-7 7-7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" fill="none" />
            <path d="M16 13v6M13 16h6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
        </svg>
    </div>

    <h1 class="auth-title">Create account</h1>
    <p class="auth-subtitle">Set up your account</p>

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <form id="registerForm" method="post">

        <p class="section-label">Personal info</p>

        <div class="form-row-2">
            <div class="form-group">
                <label class="form-label">First name</label>
                <input asp-for="Input.FirstName" class="form-control" placeholder="Jane" />
                <span asp-validation-for="Input.FirstName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Last name <span style="color:var(--text-muted)">(optional)</span></label>
                <input asp-for="Input.LastName" class="form-control" placeholder="Smith" />
                <span asp-validation-for="Input.LastName" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Phone number <span style="color:var(--text-muted)">(optional)</span></label>
            <div class="input-wrapper">
                <span class="input-icon">
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                        <path d="M3 2h3l1.5 3.5-1.75 1.25a8.5 8.5 0 0 0 3.5 3.5L10.5 8.5 14 10v3a1 1 0 0 1-1 1C5.5 14 2 7.5 2 3a1 1 0 0 1 1-1z" stroke="currentColor" stroke-width="1.3" fill="none" stroke-linejoin="round" />
                    </svg>
                </span>
                <input asp-for="Input.PhNumber" class="form-control" placeholder="+1 555 000 0000" />
            </div>
            <span asp-validation-for="Input.PhNumber" class="text-danger"></span>
        </div>

        <div class="auth-divider"></div>
        <p class="section-label" style="margin-top:0">Account credentials</p>

        <div class="form-group">
            <label class="form-label">Email address</label>
            <div class="input-wrapper">
                <span class="input-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                        <rect x="1.5" y="3.5" width="13" height="9" rx="1.5" stroke="currentColor" stroke-width="1.3" fill="none" />
                        <path d="M1.5 5.5l6.5 4 6.5-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                    </svg>
                </span>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="you@example.com" />
            </div>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="form-row-2">
            <div class="form-group">
                <label class="form-label">Password</label>
                <div class="input-wrapper">
                    <span class="input-icon">
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                            <rect x="2" y="7.5" width="12" height="7" rx="1.5" stroke="currentColor" stroke-width="1.3" fill="none" />
                            <path d="M5 7.5V5.5a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" fill="none" />
                        </svg>
                    </span>
                    <input asp-for="Input.Password" class="form-control" type="password" placeholder="Min 6 chars" />
                </div>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Confirm password</label>
                <div class="input-wrapper">
                    <span class="input-icon">
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                            <path d="M3 8l3.5 3.5L13 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </span>
                    <input asp-for="Input.ConfirmPassword" class="form-control" type="password" placeholder="Repeat password" />
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>
        </div>

        <div class="auth-divider"></div>
        <p class="section-label" style="margin-top:0">Security PIN</p>

        <div class="form-group">
            <label class="form-label">5-digit PIN <span style="color:var(--text-muted);font-size:12px">— used for quick vault access</span></label>
            <div class="input-wrapper">
                <span class="input-icon">
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                        <circle cx="5" cy="6" r="1.5" fill="currentColor" opacity="0.6" />
                        <circle cx="8" cy="6" r="1.5" fill="currentColor" opacity="0.6" />
                        <circle cx="11" cy="6" r="1.5" fill="currentColor" opacity="0.6" />
                        <circle cx="5" cy="10" r="1.5" fill="currentColor" opacity="0.6" />
                        <circle cx="8" cy="10" r="1.5" fill="currentColor" opacity="0.6" />
                    </svg>
                </span>
                <input asp-for="Input.Pin" class="form-control pin-input" type="password" maxlength="5" placeholder="•••••" inputmode="numeric" />
            </div>
            <span asp-validation-for="Input.Pin" class="text-danger"></span>
        </div>

        <div style="margin-top:1.75rem;">
            <button type="submit" class="btn-vault">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                    <rect x="2" y="8" width="12" height="7" rx="1.5" fill="currentColor" opacity="0.85" />
                    <path d="M5 8V5.5a3 3 0 0 1 6 0V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none" />
                    <circle cx="8" cy="11.5" r="1.2" fill="white" opacity="0.8" />
                </svg>
                Create my vault
            </button>
        </div>

    </form>

    <div class="auth-footer">
        Already have an account? <a asp-area="Identity" asp-page="/Account/Login">Sign in</a>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
